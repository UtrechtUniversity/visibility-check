# Visibility Check seeding configuration
# Path to the SQL dump used by content-only seeders. Relative to backend base_path() is allowed.
VC_SEED_SQL_PATH=docker/mariadb/B_data.sql
# When true, seeders will TRUNCATE their table before importing (fully idempotent, no duplicates).
VC_SEED_TRUNCATE=false
# When not truncating, choose how to insert: 'ignore' (default) uses INSERT IGNORE to skip duplicates; 'normal' uses plain INSERT.
VC_SEED_INSERT_MODE=ignore
